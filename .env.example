# Inbound auth key — clients must send this in X-API-Key header
API_KEY=change-me

# LLM providers — configure at least one
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=8192

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=8192

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=agent_lab
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Embeddings
# "sentence_transformers" (local, via worker) or "openai"
EMBEDDING_BACKEND=sentence_transformers
ST_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384
WORKER_EMBED_URL=http://worker:8001
# Only needed when EMBEDDING_BACKEND=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Worker
WORKER_API_KEY=
EMBEDDING_WORKER_POLL_INTERVAL=2.0
EMBEDDING_JOB_MAX_ATTEMPTS=3

# Token budget — rolling 4-hour window per user
TOKEN_BUDGET=10000
TOKEN_WINDOW_HOURS=4

# Context limits
CONTEXT_DIRECT_LIMIT=20
CONTEXT_SEMANTIC_LIMIT=4
CROSS_CHAT_SEMANTIC_LIMIT=2
CONTEXT_FACTS_LIMIT=3
FACT_DEDUP_THRESHOLD=0.15
FACTS_PER_USER_LIMIT=20

# Chain lifecycle
CHAIN_GAP_SECONDS=5
MAX_CHAIN_AGE_SECONDS=300

# Concurrency
MAX_CHAT_CONCURRENT=5
